concept_delivery_route
<- sc_node_class;
<- class;

=> nrel_main_idtf:
    [Маршрут доставки] (* <- lang_ru;; *);
    [Delivery Route] (* <- lang_en;; *);

=> nrel_note:
    [Логистический маршрут, по которому осуществляется доставка онлайн-заказов
     в пределах определённого региона, оптимизированный по времени и стоимости.]
    (* <- lang_ru;; *);;